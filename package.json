{
  "name": "travelai-backend",
  "version": "1.0.0",
  "description": "Backend API for TravelAI - Smart Travel Website",
  "main": "src/server.js",
  "scripts": {
    "start": "node src/server.js",
    "dev": "nodemon src/server.js",
    "seed:admin": "node src/scripts/seedAdmin.js",
    "seed:destinations": "node src/scripts/seedDestinations.js",
    "seed:cuisine": "node src/scripts/seedCuisine.js",
    "seed:travinh": "node src/scripts/seedTraVinh.js",
    "seed:all": "node src/scripts/seedAdmin.js && node src/scripts/seedDestinations.js && node src/scripts/seedCuisine.js",
    "add:baisau": "node src/scripts/addBaiSau.js",
    "update:images": "node src/scripts/updateDestinationImages.js",
    "update:travinh": "node src/scripts/updateTraVinhCoordinates.js",
    "fix:baisao": "node src/scripts/fixBaiSaoCoordinates.js"
  },
  "dependencies": {
    "@cerebras/cerebras_cloud_sdk": "^1.64.1",
    "@types/leaflet": "^1.9.21",
    "axios": "^1.16.0",
    "bcryptjs": "^2.4.3",
    "compression": "^1.8.1",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.21.0",
    "express-validator": "^7.2.0",
    "google-auth-library": "^10.7.0",
    "jsonwebtoken": "^9.0.2",
    "leaflet": "^1.9.4",
    "mongoose": "^8.6.0",
    "node-cron": "^4.2.1",
    "openai": "^6.32.0",
    "react-leaflet": "^5.0.0",
    "socket.io": "^4.8.3",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.1"
  },
  "devDependencies": {
    "nodemon": "^3.1.4"
  }
}

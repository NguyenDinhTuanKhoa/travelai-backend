PORT=5000
MONGODB_URI=mongodb+srv://<username>:<password>@cluster.mongodb.net/travelai?retryWrites=true&w=majority
JWT_SECRET=your_jwt_secret_key_here
JWT_EXPIRE=7d

# CORS allowlist — URL frontend được phép gọi API (phân cách bằng dấu phẩy).
# Để trống = cho phép tất cả origin (chỉ nên dùng khi dev).
CLIENT_URL=http://localhost:3000

# API Keys
OPENWEATHER_API_KEY=your_openweather_api_key_here
NVIDIA_API_KEY=your_nvidia_api_key_here
OPENCODE_API_KEY=your_opencode_api_key_here

# AI provider mặc định: gpt55 (GPT-5.5 qua highwayapi.ai) | nvidia (step-3.7-flash) | opencode
AI_PROVIDER=nvidia

# GPT-5.5 qua highwayapi.ai (jiekou.ai). HIGHWAY_API_KEYS nhận NHIỀU key (phân cách phẩy),
# hệ thống tự xoay vòng khi 1 key hết quota rồi mới fallback sang NVIDIA.
HIGHWAY_API_KEYS=key1,key2

# Web search keys (phân cách bằng dấu phẩy, hệ thống tự xoay vòng khi key hết quota)
SERPER_API_KEY=your_serper_api_key_here
SERPAPI_KEYS=key1,key2,key3
